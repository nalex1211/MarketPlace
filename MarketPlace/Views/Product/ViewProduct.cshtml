@model Products

<div class="card mb-4 box-shadow">
    @*<img class="card-img-top" data-src="holder.js/100px225?theme=thumb&bg=55595c&fg=eceeef&text=Thumbnail" alt="Card image cap">*@
    <div class="card-body">
        <p class="card-text">Name-@Model.Name</p>
        <p class="card-text">Price-@Model.Price</p>
        <p class="card-text">Category-@Model.Category.Name</p>
        <div class="d-flex justify-content-between align-items-center">
            <div class="btn-group">
                <a asp-controller="Product" asp-action="BuyProduct" asp-route-id="@Model.Id" type="button" class="btn btn-sm btn-outline-secondary">Buy</a>
            </div>
        </div>
    </div>
</div>