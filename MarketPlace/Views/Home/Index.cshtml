@model List<Products>

<label style="font-size:30px;text-align:center;display:block" asp-validation-for="@User.Identity?.IsAuthenticated" class="text-danger">@TempData["NotLoggedIn"]</label>
<div style="border-radius:20px" class="album py-4 bg-light">
    <div class="container">
        <div class="row">
            @foreach (var prod in Model)
            {
                <div class="col-md-4">
                    <div class="card mb-4 box-shadow">
                        @*<img class="card-img-top" data-src="holder.js/100px225?theme=thumb&bg=55595c&fg=eceeef&text=Thumbnail" alt="Card image cap">*@
                        <a asp-controller="Product" asp-action="ViewProduct" type="button" class="btn" asp-route-id="@prod.Id">
                            <div style="float:left">
                                <p class="card-text">Name-@prod.Name</p>
                                <p class="card-text">Price-@prod.Price</p>
                                <p class="card-text">Category-@prod.Category.Name</p>
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

